# ── Server ─────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://127.0.0.1:5500

# ── MongoDB ────────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/nitjaa_election

# ── Email (Gmail SMTP) ─────────────────────────────────────────────────────────
# Enable "App Password" in your Google account (not your regular password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_16_char_app_password
EMAIL_FROM="NITJAA Election Cell <your_gmail@gmail.com>"

# ── Admin JWT ──────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
ADMIN_JWT_SECRET=replace_with_a_very_long_random_string_here

# ── Admin Seed Credentials (run: npm run seed:admin) ──────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin@NITJ2024

# ── File Upload ────────────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=5
