PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/nitj_nominations

# Gmail SMTP (use App Password — enable 2FA first)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-16-char-app-password
EMAIL_FROM=NIT Jalandhar Elections <your-email@gmail.com>

# Security
SESSION_SECRET=replace-with-64-char-random-string

# Frontend origin (for CORS)
FRONTEND_URL=http://localhost:3000

# OTP
OTP_EXPIRY_MINUTES=10

# File upload
MAX_FILE_SIZE_MB=5
